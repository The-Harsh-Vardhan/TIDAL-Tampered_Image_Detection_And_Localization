{
  "dashboard": {
    "title": "TIDAL Dashboard",
    "uid": "tidal-main",
    "panels": [
      {
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(tidal_requests_total[5m])"
          }
        ]
      },
      {
        "title": "Latency P99",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99,rate(tidal_request_duration_seconds_bucket[5m]))"
          }
        ]
      }
    ]
  }
}